;;; Levenshtein distance benchmark: two-row DP, "kitten" -> "sitting".
;;; Run: sbcl --script levenshtein.lisp

(declaim (optimize (speed 3) (safety 0) (debug 0)))

(defun levenshtein (s1 s2)
  (declare (simple-string s1 s2))
  (let ((len1 (length s1))
        (len2 (length s2)))
    (declare (fixnum len1 len2))
    (when (< len2 len1)
      (rotatef s1 s2)
      (rotatef len1 len2))
    (let ((prev (make-array (1+ len1) :element-type 'fixnum))
          (curr (make-array (1+ len1) :element-type 'fixnum)))
      (dotimes (j (1+ len1))
        (setf (aref prev j) j))
      (dotimes (i len2)
        (declare (fixnum i))
        (setf (aref curr 0) (1+ i))
        (dotimes (j len1)
          (declare (fixnum j))
          (let* ((cost (if (char= (char s1 j) (char s2 i)) 0 1))
                 (del (1+ (aref prev (1+ j))))
                 (ins (1+ (aref curr j)))
                 (sub (+ (aref prev j) cost)))
            (declare (fixnum cost del ins sub))
            (setf (aref curr (1+ j)) (min del ins sub))))
        (rotatef prev curr))
      (aref prev len1))))

(defun now-ms ()
  (/ (* (get-internal-real-time) 1000.0d0)
     internal-time-units-per-second))

(defun main ()
  (let ((s1 "kitten")
        (s2 "sitting")
        (iters 10000)
        (result 0))
    (declare (fixnum iters result))
    (let ((start (now-ms)))
      (dotimes (i iters)
        (setf result (levenshtein s1 s2)))
      (let ((elapsed (- (now-ms) start)))
        (format t "result=~d time=~,1f ms (~d iters)~%" result elapsed iters)))))

(main)
